# Local development example for Otter Web
# Copy to .dev.vars before running pnpm dev

# Neon Postgres direct connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-random-secret
BETTER_AUTH_URL=http://localhost:5678
BETTER_AUTH_ALLOW_SIGNUP=false

# Frontend flags
VITE_ALLOW_SIGNUP=false

# Raycast OAuth
RAYCAST_OAUTH_CLIENT_ID=

# Optional integrations
BOT_MASTODON_ACCESS_TOKEN=
PERSONAL_MASTODON_ACCESS_TOKEN=
WEBHOOK_SECRET=replace-with-a-random-secret

# Billing — Stripe
# Public origin of the app, used to build Stripe redirect URLs.
# Falls back to BETTER_AUTH_URL when unset.
APP_URL=http://localhost:5678
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring price ID for the Pro subscription (Stripe Dashboard → Products).
STRIPE_PRICE_ID=price_xxx

# Free plan: number of new bookmarks allowed per day.
# Optional — defaults to 10 when unset.
FREE_DAILY_BOOKMARK_LIMIT=10

# Local development example for Otter Web
# Copy to .dev.vars before running pnpm dev

# Neon Postgres direct connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-random-secret
BETTER_AUTH_URL=http://localhost:5678

# Allow new user registration. Build-time flag — read by both the SPA
# and the worker. Defaults to disabled; set to 'true' to allow signups.
VITE_ALLOW_SIGNUP=true

# Raycast OAuth
RAYCAST_OAUTH_CLIENT_ID=

# Optional integrations
BOT_MASTODON_ACCESS_TOKEN=
PERSONAL_MASTODON_ACCESS_TOKEN=
WEBHOOK_SECRET=replace-with-a-random-secret

# Billing — Stripe
# Master switch for all paid-tier features (checkout, daily quota,
# Pro-gated AI, billing/pricing UI). Build-time flag — read by both the SPA
# and the worker. Defaults to enabled; set to 'false' to run Otter as a
# single-tier free instance (every user gets unlimited bookmarks and full
# AI access). When 'false', the rest of the Stripe vars below are unused.
VITE_BILLING_ENABLED=true

# Public origin of the app, used to build Stripe redirect URLs.
# Falls back to BETTER_AUTH_URL when unset.
APP_URL=http://localhost:5678
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Stripe price IDs (Stripe Dashboard → Products). One product, three prices:
#   monthly  — recurring
#   annual   — recurring
#   lifetime — one-off
STRIPE_PRICE_ID_MONTHLY=price_xxx
STRIPE_PRICE_ID_ANNUAL=price_xxx
STRIPE_PRICE_ID_LIFETIME=price_xxx

# Free plan: number of new bookmarks allowed per day.
# Optional — defaults to 10 when unset.
FREE_DAILY_BOOKMARK_LIMIT=10

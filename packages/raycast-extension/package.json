{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "author": "mrmartineau",
  "categories": [
    "Applications",
    "Productivity"
  ],
  "commands": [
    {
      "description": "Search Otter",
      "interval": "10m",
      "mode": "view",
      "name": "search",
      "subtitle": "Otter",
      "title": "Search Bookmarks"
    },
    {
      "description": "View recent Otter items",
      "interval": "10m",
      "mode": "view",
      "name": "recent",
      "subtitle": "Otter",
      "title": "Recent Bookmarks"
    },
    {
      "description": "Add new bookmark",
      "mode": "view",
      "name": "add",
      "subtitle": "Otter",
      "title": "Add Bookmark"
    },
    {
      "description": "View recent Otter items",
      "interval": "5m",
      "mode": "menu-bar",
      "name": "menubar",
      "title": "View Recent Bookmarks"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.68.1",
    "@raycast/utils": "^1.10.0",
    "node-fetch": "^3.3.2",
    "proper-url-join": "^2.1.1",
    "run-applescript": "^6.1.0",
    "tiny-relative-date": "^1.3.0",
    "title": "^3.5.3"
  },
  "description": "Companion bookmarking utility for Otter bookmarks",
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.6",
    "@types/node": "^20.8.5",
    "@types/proper-url-join": "^2.1.2",
    "@types/react": "^18.2.28",
    "eslint": "^8.51.0",
    "react-devtools": "^4.28.4",
    "typescript": "^5.9.3"
  },
  "icon": "command-icon.png",
  "license": "MIT",
  "name": "otter",
  "owner": "zedd-emm",
  "preferences": [
    {
      "description": "Your Raycast OAuth client ID from Otter",
      "name": "oauthClientId",
      "placeholder": "edd55904-3f55-4bea-ae6d-ebfcf662a21e",
      "required": true,
      "title": "OAuth Client ID",
      "type": "textfield"
    },
    {
      "default": "https://otter.zander.wtf",
      "description": "e.g. https://otter.zander.wtf",
      "name": "otterBasePath",
      "required": true,
      "title": "Otter Instance URL",
      "type": "textfield"
    },
    {
      "default": true,
      "description": "Show detail view to side or list view",
      "label": "Show detail view",
      "name": "showDetailView",
      "required": true,
      "title": "Show Detail View to Side or List View",
      "type": "checkbox"
    }
  ],
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "lint:fix": "ray lint --fix",
    "publish": "npx @raycast/api@latest publish"
  },
  "subtitle": "Otter",
  "title": "Otter Bookmarks"
}
